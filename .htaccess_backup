# Enable URL rewriting
RewriteEngine On

# Make sure this runs only if file/folder doesn't exist
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Allow URLs without .php extension
RewriteRule ^([^/]+)/?$ $1.php [L,QSA]

# For subfolders like vr/, pages/, etc.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/?$ $1.php [L,QSA]


RewriteRule ^vr/(.*)$ vr.php?slug=$1 [L,QSA]
