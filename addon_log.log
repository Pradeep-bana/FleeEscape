    [description] => <p><span style="color: #c0c0c0; font-family: 'arial black', 'avant garde'; font-size: large;">Players: 2-8&nbsp;</span></p>
<p><span style="font-family: 'arial black', 'avant garde'; color: #c0c0c0; font-size: large;">Difficulty: Intermediate-Advance</span></p>
<p dir="ltr"><span style="font-family: 'arial black', 'avant garde'; color: #c0c0c0; font-size: large;">Success Rate: 48%</span></p>
<p dir="ltr"><span style="font-family: 'arial black', 'avant garde'; color: #c0c0c0; font-size: large;">Price: $40/Player ($45/player for a group of 2)</span></p>
