    [name] => THE LIFT (PRIVATE GAME ONLY)
    [description] => <p dir="ltr"><span style="font-family: 'arial black', 'avant garde'; font-size: large; color: #c0c0c0;">Players: 2-4&nbsp;</span></p>
<p dir="ltr"><span style="font-family: 'arial black', 'avant garde'; font-size: large; color: #c0c0c0;">Difficulty: Novice</span></p>
