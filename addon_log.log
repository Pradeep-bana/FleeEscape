    [name] => Flee Escape and Zero Latency VR Summer Camp 2025 - Kids 9 and above
    [description] => <div style="max-width: 1100px; margin: auto; font-family: 'Segoe UI', sans-serif; color: #f4f4f4; background-color: #101820; padding: 40px 20px; border-radius: 16px; box-shadow: 0 0 20px rgba(0,255,255,0.1);">
