    [name] => TEAM EVENT DEPOSIT FOR 9+ PLAYERS (PRIVATE EVENT)
    [description] => <div><span style="font-family: arial, helvetica, sans-serif; font-size: large; color: #c0c0c0;">&nbsp;</span></div>
