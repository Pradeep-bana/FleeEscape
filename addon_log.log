    [name] => PRISON ESCAPE (PRIVATE GAME ONLY)
    [description] => <p><span style="font-family: 'arial black', 'avant garde'; color: #c0c0c0; font-size: large;">Players: 2-8&nbsp;</span></p>
<p dir="ltr"><span style="font-family: 'arial black', 'avant garde'; color: #c0c0c0; font-size: large;">Difficulty: Novice-Intermediate</span></p>
<p dir="ltr"><span style="font-family: 'arial black', 'avant garde'; color: #c0c0c0; font-size: large;">Success Rate: 65%</span><span style="font-size: large;">&nbsp;</span></p>
