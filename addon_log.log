    [name] => ANCIENT EGYPT (PRIVATE GAME ONLY)
    [description] => <p dir="ltr"><span style="font-family: 'arial black', 'avant garde'; font-size: large; color: #c0c0c0;">Players: 2-8&nbsp;</span></p>
<p dir="ltr"><span style="font-family: 'arial black', 'avant garde'; font-size: large; color: #c0c0c0;">Difficulty: Intermediate-Advanced</span></p>
<p dir="ltr"><span style="font-family: 'arial black', 'avant garde'; font-size: large; color: #c0c0c0;">Success Rate: 55%</span></p>
